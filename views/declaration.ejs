<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Health Declaration</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-teal-700 min-h-screen flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 text-center">
        <h1 class="text-2xl font-bold text-green-700 mb-6">Welcome, How do you feel today: Mr. <%= user.name %></h1>
        <div class="grid grid-cols-2 gap-4 mb-8">
            <button onclick="sel('Well')" id="bw" class="border-2 border-green-600 text-green-600 py-4 rounded-2xl font-bold text-xl hover:bg-green-50">Well</button>
            <button onclick="sel('Not Well')" id="bnw" class="border-2 border-red-600 text-red-600 py-4 rounded-2xl font-bold text-xl hover:bg-red-50">Not Well</button>
        </div>
        <form action="/submit" method="POST" id="form" class="hidden">
            <input type="hidden" name="userId" value="<%= user.id %>">
            <input type="hidden" name="status" id="statInput">
            <label class="flex items-start gap-3 text-left bg-blue-50 p-4 rounded-xl mb-6 cursor-pointer">
                <input type="checkbox" name="tbmConfirmed" required class="mt-1 w-5 h-5">
                <span class="text-sm text-gray-600 font-medium">I confirm I have received and understood today's TBM topics.</span>
            </label>
            <button class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold text-lg shadow-lg shadow-blue-200">Save & Exit</button>
        </form>
        <div class="mt-8 pt-6 border-t flex justify-center gap-4">
            <button onclick="document.getElementById('pwForm').classList.toggle('hidden')" class="bg-yellow-500 text-white px-4 py-2 rounded-lg font-bold text-xs uppercase">Change Passcode</button>
            <a href="/" class="bg-gray-500 text-white px-4 py-2 rounded-lg font-bold text-xs uppercase">Logout</a>
        </div>
        <form action="/update-passcode" method="POST" id="pwForm" class="hidden mt-4 p-4 bg-gray-50 rounded-xl">
            <input type="hidden" name="userId" value="<%= user.id %>">
            <input type="password" name="newPasscode" placeholder="New PIN" required class="w-full border p-2 rounded-lg mb-2">
            <button class="w-full bg-black text-white py-2 rounded-lg text-xs font-bold">Confirm Change</button>
        </form>
    </div>
    <script>
        function sel(s) {
            document.getElementById('statInput').value = s;
            document.getElementById('form').classList.remove('hidden');
            document.getElementById('bw').classList.toggle('bg-green-100', s==='Well');
            document.getElementById('bnw').classList.toggle('bg-red-100', s!=='Well');
        }
    </script>
</body>
</html>