<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>PTJV | Periodic Health Analysis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @media print { .no-print { display: none; } body { background: white; } .print-card { border: 1px solid #e2e8f0; box-shadow: none; } }
        .progress-bar { transition: width 1s ease-in-out; }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-900">

    <nav class="no-print bg-[#002b5c] p-4 text-white flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <img src="/logo/ptjvlogo.png" class="h-8 bg-white p-1 rounded">
            <span class="font-bold tracking-widest text-sm border-l pl-4 border-white/20">ANALYSIS ENGINE</span>
        </div>
        <div class="flex gap-3">
            <a href="/admin?key=<%= adminKey %>" class="text-xs bg-white/10 px-4 py-2 rounded-lg hover:bg-white/20 transition">Back to Panel</a>
            <button onclick="window.print()" class="text-xs bg-yellow-500 text-black px-4 py-2 rounded-lg font-bold hover:bg-yellow-400">Export PDF</button>
        </div>
    </nav>

    <main class="p-6 lg:p-12 max-w-7xl mx-auto">
        
        <div class="no-print bg-white p-8 rounded-[2rem] shadow-xl shadow-slate-200/50 mb-10 border border-white">
            <h2 class="text-2xl font-black mb-6 text-slate-800">Choose Analysis Period</h2>
            <form action="/admin/analysis" method="GET" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
                <input type="hidden" name="key" value="<%= adminKey %>">
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Start Date</label>
                    <input type="date" name="startDate" value="<%= startDate %>" required class="w-full mt-1 bg-slate-50 border-none rounded-2xl p-4 focus:ring-2 focus:ring-blue-500 transition">
                </div>
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">End Date</label>
                    <input type="date" name="endDate" value="<%= endDate %>" required class="w-full mt-1 bg-slate-50 border-none rounded-2xl p-4 focus:ring-2 focus:ring-blue-500 transition">
                </div>
                <button class="bg-[#002b5c] text-white py-4 rounded-2xl font-bold shadow-lg shadow-blue-900/20 hover:scale-[1.02] active:scale-95 transition">
                    Run Analysis
                </button>
            </form>
        </div>

        <% if (startDate && endDate) { %>
            <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4">
                <div>
                    <h1 class="text-4xl font-black text-slate-900 tracking-tight">Personnel Health Report</h1>
                    <p class="text-slate-400 font-medium">Data spanning from <span class="text-blue-600 underline font-bold"><%= startDate %></span> to <span class="text-blue-600 underline font-bold"><%= endDate %></span></p>
                </div>
                <div class="bg-blue-600 text-white px-6 py-3 rounded-2xl font-bold text-sm shadow-lg shadow-blue-200">
                    Range Verified ✓
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-100 print-card">
                    <p class="text-[10px] font-black text-slate-400 uppercase mb-2">Total Declarations</p>
                    <p class="text-4xl font-black text-slate-800"><%= overallStats.totalLogs %></p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-100 print-card">
                    <p class="text-[10px] font-black text-green-500 uppercase mb-2">Healthy Status</p>
                    <p class="text-4xl font-black text-green-600"><%= overallStats.well %></p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-100 print-card">
                    <p class="text-[10px] font-black text-red-500 uppercase mb-2">Medical Issues</p>
                    <p class="text-4xl font-black text-red-600"><%= overallStats.notWell %></p>
                </div>
                <div class="bg-[#002b5c] p-6 rounded-[2rem] shadow-xl text-white">
                    <p class="text-[10px] font-black text-blue-200 uppercase mb-2">Avg. Compliance</p>
                    <p class="text-4xl font-black"><%= reportData.length > 0 ? Math.round(reportData.reduce((acc, curr) => acc + curr.complianceScore, 0) / reportData.length) : 0 %>%</p>
                </div>
            </div>

            <div class="bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 overflow-hidden border border-white mb-10">
                <div class="p-8 border-b border-slate-50 flex justify-between items-center">
                    <h3 class="font-black text-xl text-slate-800 italic">Personnel Compliance Breakdown</h3>
                    <i class="fas fa-filter text-slate-300"></i>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50/50 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                            <tr>
                                <th class="p-6">Employee</th>
                                <th class="p-6">Days Submitted</th>
                                <th class="p-6">Health Quality</th>
                                <th class="p-6">Compliance Score</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% reportData.forEach(user => { %>
                                <tr class="hover:bg-slate-50/80 transition">
                                    <td class="p-6">
                                        <p class="font-black text-slate-800"><%= user.name %></p>
                                        <p class="text-[10px] font-bold text-slate-400 uppercase"><%= user.position %></p>
                                    </td>
                                    <td class="p-6">
                                        <span class="text-xl font-bold text-slate-700"><%= user.submissionCount %></span>
                                        <span class="text-slate-300 text-xs">entries</span>
                                    </td>
                                    <td class="p-6">
                                        <div class="flex items-center gap-4">
                                            <span class="text-xs font-bold text-green-600"><%= user.wellCount %> Well</span>
                                            <div class="h-2 w-20 bg-slate-100 rounded-full overflow-hidden flex">
                                                <div class="bg-green-500 h-full" style="width: <%= (user.wellCount/user.submissionCount)*100 %>%"></div>
                                                <div class="bg-red-500 h-full" style="width: <%= (user.notWellCount/user.submissionCount)*100 %>%"></div>
                                            </div>
                                            <span class="text-xs font-bold text-red-500"><%= user.notWellCount %> Not Well</span>
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <div class="flex items-center gap-3">
                                            <div class="flex-1 bg-slate-100 h-3 rounded-full overflow-hidden">
                                                <div class="progress-bar bg-blue-600 h-full rounded-full" style="width: <%= user.complianceScore %>%"></div>
                                            </div>
                                            <span class="font-black text-slate-800 w-10"><%= user.complianceScore %>%</span>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <footer class="text-center pb-20 no-print">
                <p class="text-slate-300 text-xs font-bold uppercase tracking-widest">End of Automated Report</p>
            </footer>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-40 opacity-20">
                <i class="fas fa-calendar-alt text-8xl mb-6"></i>
                <p class="text-2xl font-black italic uppercase">Select a date range to generate analysis</p>
            </div>
        <% } %>
    </main>

</body>
</html>