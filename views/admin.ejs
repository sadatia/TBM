<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | PTJV</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-slate-100 font-sans flex flex-col md:flex-row">
    
    <div class="bg-[#002b5c] w-full md:w-64 md:min-h-screen p-6 text-white flex md:flex-col justify-between">
        <div>
            <img src="/logo/ptjvlogo.png" class="h-10 mb-8 bg-white p-1 rounded">
            <nav class="space-y-4">
                <a href="#" class="block p-3 bg-white/10 rounded-xl font-bold border-l-4 border-yellow-500"><i class="fas fa-home mr-3"></i> Dashboard</a>
                <a href="/" class="block p-3 hover:bg-white/10 rounded-xl text-gray-400 transition"><i class="fas fa-external-link-alt mr-3"></i> Public Site</a>
                <a href="/admin/analysis?key=<%= adminKey %>" class="block p-3 hover:bg-white/10 rounded-xl text-gray-400 transition">
    <i class="fas fa-chart-pie mr-3"></i> Analysis & Reports
</a>
            
            </nav>
        </div>
    </div>

    <main class="flex-1 p-6 md:p-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-white p-6 rounded-3xl shadow-sm border-b-4 border-blue-500">
                <p class="text-xs font-bold text-gray-400 uppercase">Total Submissions</p>
                <h3 class="text-3xl font-black"><%= stats.total %></h3>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border-b-4 border-green-500 text-green-600">
                <p class="text-xs font-bold text-gray-400 uppercase">Feeling Well</p>
                <h3 class="text-3xl font-black"><%= stats.well %></h3>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border-b-4 border-red-500 text-red-600">
                <p class="text-xs font-bold text-gray-400 uppercase">Feeling Not Well</p>
                <h3 class="text-3xl font-black"><%= stats.notWell %></h3>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white p-8 rounded-3xl shadow-sm">
                <h2 class="text-lg font-bold mb-6 italic border-b pb-2">Add New Personnel</h2>
                <form action="/admin/add-user?key=<%= adminKey %>" method="POST" class="space-y-4">
                    <input type="text" name="name" placeholder="Full Name" required class="w-full bg-slate-50 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 transition">
                    <input type="text" name="position" placeholder="Job Position" required class="w-full bg-slate-50 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 transition">
                    <button class="w-full bg-[#002b5c] text-white py-4 rounded-2xl font-bold shadow-lg shadow-blue-100 hover:scale-[1.02] active:scale-95 transition">Register User</button>
                </form>
            </div>

            <div class="bg-white rounded-3xl shadow-sm overflow-hidden border">
                <div class="p-4 bg-slate-50 font-bold border-b italic">Live Status Log (Today)</div>
                <div class="max-h-[300px] overflow-y-auto">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase sticky top-0">
                            <tr><th class="p-4">Name</th><th class="p-4">Status</th><th class="p-4 text-center">TBM</th><th class="p-4">Time</th></tr>
                        </thead>
                        <tbody class="divide-y">
                            <% records.slice().reverse().forEach(r => { %>
                                <tr class="text-sm">
                                    <td class="p-4 font-bold"><%= r.name %></td>
                                    <td class="p-4"><span class="px-2 py-1 rounded font-black text-[10px] uppercase <%= r.status === 'Well' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>"><%= r.status %></span></td>
                                    <td class="p-4 text-center"><%= r.tbm ? '✅' : '❌' %></td>
                                    <td class="p-4 text-gray-400"><%= r.time %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm overflow-hidden border lg:col-span-2">
                <div class="p-4 bg-slate-50 font-bold border-b italic flex justify-between items-center">
                    <span>Registered Personnel Management</span>
                    <span class="text-xs text-gray-400 font-normal">Total Users: <%= users.length %></span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase">
                            <tr>
                                <th class="p-4">ID</th>
                                <th class="p-4">Name</th>
                                <th class="p-4">Position</th>
                                <th class="p-4">Passcode</th>
                                <th class="p-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
    <% users.forEach(u => { %>
        <tr class="text-sm hover:bg-slate-50 transition">
            <td class="p-4 text-gray-400"><%= u.id %></td>
            <td class="p-4 font-bold"><%= u.name %></td>
            <td class="p-4 text-gray-500"><%= u.position %></td>
            <td class="p-4 font-mono text-blue-600"><%= u.passcode %></td>
            <td class="p-4 text-right flex justify-end gap-2">
                <button onclick="openEditModal('<%= u.id %>', '<%= u.name %>', '<%= u.passcode %>')" 
                        class="bg-blue-100 text-blue-600 px-3 py-1 rounded-lg hover:bg-blue-600 hover:text-white transition">
                    <i class="fas fa-edit"></i>
                </button>

                <form action="/admin/delete-user?key=<%= adminKey %>" method="POST" onsubmit="return confirm('Are you sure you want to delete <%= u.name %>? This action cannot be undone.');">
                    <input type="hidden" name="userId" value="<%= u.id %>">
                    <button type="submit" class="bg-red-100 text-red-600 px-3 py-1 rounded-lg hover:bg-red-600 hover:text-white transition">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </form>
            </td>
        </tr>
    <% }) %>
</tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="editModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold text-gray-800 underline decoration-yellow-500 decoration-4 underline-offset-8">Edit Personnel</h2>
                <button onclick="closeEditModal()" class="text-gray-400 text-2xl hover:text-red-500 transition">&times;</button>
            </div>
            
            <form action="/admin/edit-user?key=<%= adminKey %>" method="POST" class="space-y-4">
                <input type="hidden" name="userId" id="editUserId">
                
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase">Full Name</label>
                    <input type="text" name="newName" id="editUserName" required 
                           class="w-full mt-1 p-3 bg-slate-50 border border-transparent rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition">
                </div>
                
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase">Passcode</label>
                    <input type="text" name="newPasscode" id="editUserPass" required 
                           class="w-full mt-1 p-3 bg-slate-50 border border-transparent rounded-xl outline-none focus:ring-2 focus:ring-blue-500 font-mono transition">
                </div>

                <div class="flex gap-3 pt-4">
                    <button type="button" onclick="closeEditModal()" class="flex-1 py-3 bg-gray-100 text-gray-600 rounded-xl font-bold hover:bg-gray-200 transition">Cancel</button>
                    <button type="submit" class="flex-1 py-3 bg-[#002b5c] text-white rounded-xl font-bold shadow-lg hover:bg-blue-900 transition">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openEditModal(id, name, pass) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editUserName').value = name;
            document.getElementById('editUserPass').value = pass;
            document.getElementById('editModal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('editModal').classList.add('hidden');
        }

        // Close modal on background click
        window.onclick = function(event) {
            let modal = document.getElementById('editModal');
            if (event.target == modal) {
                closeEditModal();
            }
        }
    </script>
</body>
</html>